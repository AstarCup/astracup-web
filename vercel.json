{
    "buildCommand": "bash scripts/build-vercel.sh",
    "installCommand": "npm install",
    "outputDirectory": ".next",
    "framework": "nextjs",
    "functions": {
        "src/app/api/**/*.ts": {
            "maxDuration": 30
        },
        "src/app/api/parse-osz/route.ts": {
            "maxDuration": 30,
            "memory": 3008,
            "maxRequestBodySize": "50mb"
        }
    },
    "env": {
        "NODE_ENV": "production"
    }
}